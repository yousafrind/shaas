# Force Unix line endings for all shell scripts
# Without this, Git on Windows converts LF→CRLF and bash scripts break

*.sh        text eol=lf
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.conf      text eol=lf
Dockerfile* text eol=lf

# Windows-native files — leave as-is
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
